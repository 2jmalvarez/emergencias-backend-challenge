{
  "name": "emergencias-challenge",
  "version": "1.0.0",
  "description": "Backend challenge API for contact agenda",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "npm run build && node dist/server.js",
    "db:up": "docker compose -f ./infra/local/postgres/docker-compose.yml up --build -d emergencias-postgres-dev",
    "db:down": "docker compose -f ./infra/local/postgres/docker-compose.yml stop emergencias-postgres-dev",
    "db:reset": "docker compose -f ./infra/local/postgres/docker-compose.yml stop emergencias-postgres-dev && docker compose -f ./infra/local/postgres/docker-compose.yml rm -f emergencias-postgres-dev && docker volume rm emergencias_pg_data_dev && docker compose -f ./infra/local/postgres/docker-compose.yml up --build -d emergencias-postgres-dev",
    "db:test:up": "docker compose -f ./infra/local/postgres/docker-compose.yml up --build -d emergencias-postgres-test",
    "db:test:down": "docker compose -f ./infra/local/postgres/docker-compose.yml stop emergencias-postgres-test",
    "db:test:reset": "docker compose -f ./infra/local/postgres/docker-compose.yml stop emergencias-postgres-test && docker compose -f ./infra/local/postgres/docker-compose.yml rm -fsv emergencias-postgres-test && docker compose -f ./infra/local/postgres/docker-compose.yml up --build -d emergencias-postgres-test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "cross-env DATABASE_URL_TEST=postgresql://emergencias:emergencias@127.0.0.1:55435/emergencias_test jest --runInBand --verbose --passWithNoTests",
    "test:integration": "cross-env DATABASE_URL_TEST=postgresql://emergencias:emergencias@127.0.0.1:55435/emergencias_test jest --runInBand --verbose --passWithNoTests tests/integration",
    "test:integration:full": "npm run db:test:reset && npm run test:integration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
